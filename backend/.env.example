PORT=3001

# Option A: full connection string
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/adn_ideologico

# Option B: separate variables
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adn_ideologico
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_WRITE=120
RATE_LIMIT_MAX_FINISH=30

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_PREDICT=900
